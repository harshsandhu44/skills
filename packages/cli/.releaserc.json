{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    "@semantic-release/changelog",
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "bun run build"
      }
    ],
    "@semantic-release/npm",
    [
      "@semantic-release/exec",
      {
        "publishCmd": "echo '//registry.npmjs.org/:_authToken=$NPM_TOKEN' >> .npmrc && npm publish --registry https://registry.npmjs.org --access public && git checkout -- .npmrc"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          {
            "path": "dist/index.js",
            "label": "CLI binary (node-compatible)"
          }
        ]
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["CHANGELOG.md", "package.json"],
        "message": "chore(release): @harshsandhu44/skills-cli ${nextRelease.version} [skip ci]"
      }
    ]
  ]
}
